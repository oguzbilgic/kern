{
  "name": "kern-ai",
  "version": "0.24.1-next",
  "description": "Simple agent runtime. Persistent memory, tools, Telegram.",
  "type": "module",
  "bin": {
    "kern": "./dist/index.js",
    "kern-ai": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "docs",
    "web/out"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc",
    "build:web": "cd web && npm run build",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "telegram",
    "cli",
    "runtime",
    "memory",
    "stateful"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/oguzbilgic/kern-ai"
  },
  "author": "Oguz Bilgic",
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/openai": "^3.0.48",
    "@inquirer/prompts": "^8.3.2",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@slack/bolt": "^4.6.0",
    "ai": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.4.0",
    "glob": "^11.0.0",
    "grammy": "^1.35.0",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.4",
    "sqlite-vec": "^0.1.8",
    "turndown": "^7.2.4",
    "unpdf": "^1.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
